    {
      "id": "pg-upsert-session",
      "name": "Postgres — Upsert session_store",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        900,
        520
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO session_store (session_key, turns, updated_at)\nVALUES ($1, $2::jsonb, NOW())\nON CONFLICT (session_key) DO UPDATE\n  SET turns = EXCLUDED.turns, updated_at = NOW();\nSELECT 1 AS ok;",
        "options": {
          "queryReplacement": "={{ $('Code — Append Turn').item.json.session_key }}, {{ $('Code — Append Turn').item.json.turns_json }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "rdxzBrj9putuOkku",
          "name": "Postgres coprem_os"
        }
      }
    },
    {
      "id": "turn-count-check",
      "name": "Turns > 10?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1120,
        640
      ],
      "parameters": {
        "conditions": {
          "options": {
            "typeValidation": "loose",
            "version": 1,
