          "name": "Redis COPREM"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const body = $('Webhook — Read Session').item.json.body;\n// Support Redis shape ($.value) and PG shape ($.value from COALESCE)\nconst raw = $input.item.json?.value || null;\n\nlet turns = [];\ntry {\n  turns = raw ? JSON.parse(raw) : [];\n  if (!Array.isArray(turns)) turns = [];\n} catch(e) {\n  turns = [];\n}\n\nconst last3 = turns.slice(-3);\nlet context = '';\nif (last3.length > 0) {\n  context = last3.map(t => `[${t.role}]: ${t.content.substring(0, 150)}`).join('\\n');\n}\n\nreturn {\n  session_key: `session:${body.channel_type}:${body.channel_id}:${body.user_id}`,\n  turns: last3,\n  context_injected: context,\n  has_context: last3.length > 0,\n  user_message: body.user_message,\n  channel_type: body.channel_type,\n  channel_id: body.channel_id,\n  user_id: body.user_id\n};"
      },
      "id": "build-context",
      "name": "Code — Build Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        300
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}"
      },
      "id": "respond-context",
      "name": "Respond — Context Payload",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1340,
        300
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "session-write",
        "responseMode": "responseNode"
      },
      "id": "trigger-write",
      "name": "Webhook — Write Session",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        520
      ],
      "webhookId": "8185da72-ef9b-4009-92b1-dd071e0957d8"
    },
    {
      "parameters": {
        "jsCode": "const body = $('Webhook — Write Session').item.json.body;\nconst pgRow = $('Postgres — Read Existing PG').item.json;\n\nlet turns = [];\ntry {\n  const raw = pgRow.turns_raw || '[]';\n  turns = JSON.parse(raw);\n  if (!Array.isArray(turns)) turns = [];\n} catch(e) {\n  turns = [];\n}\n\nturns.push({ role: 'user', content: body.user_message, ts: Date.now() });\nif (body.agent_reply) {\n  turns.push({ role: 'assistant', content: body.agent_reply, ts: Date.now() });\n}\n\nconst trimmed = turns.slice(-10);\n\nreturn {\n  session_key: body.session_key,\n  turns_json: JSON.stringify(trimmed),\n  turn_count: trimmed.length\n};"
      },
      "id": "append-turn",
      "name": "Code — Append Turn",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        520
      ]
    },
    {
      "parameters": {
        "operation": "set",
        "key": "={{ $json.session_key }}",
        "value": "={{ $json.turns_json }}",
        "expire": true,
        "ttl": 1800
      },
      "id": "redis-write",
      "name": "Redis — Write + TTL 30min",
      "type": "n8n-nodes-base.redis",
      "typeVersion": 1,
      "position": [
        1120,
        520
      ],
      "credentials": {
        "redis": {
          "id": "uOsaW3y6DV0CKN9l",
          "name": "Redis COPREM"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
