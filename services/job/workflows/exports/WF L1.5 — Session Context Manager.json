        900,
        460
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO audit_log (event_type, source, payload) VALUES ('SESSION_CACHE_MISS', 'L1.5', $1::jsonb); SELECT 1 AS ok;",
        "options": {
          "queryReplacement": "={{ JSON.stringify({ session_key: 'session:' + $('Webhook — Read Session').item.json.body.channel_type + ':' + $('Webhook — Read Session').item.json.body.channel_id + ':' + $('Webhook — Read Session').item.json.body.user_id }) }}"
        }
      },
