            "leftValue": ""
          },
          "conditions": [
            {
              "id": "tc",
              "leftValue": "={{ $('Code — Append Turn').item.json.turn_count }}",
              "rightValue": 10,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
