      ],
      "credentials": {
        "telegramApi": {
          "id": "",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"status\":\"synced\",\"kb_id\":\"{{ $('Map File to KB').item.json.kb_id }}\",\"source_file\":\"{{ $('Map File to KB').item.json.source_file }}\"}"
      },
      "id": "048415aa-c90f-4e6d-9b48-cf1e020ba011",
      "name": "Respond OK",
