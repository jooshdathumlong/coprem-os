        }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "=❌ KB Sync Failed\nFile: {{ $('Map File to KB').item.json.source_file }}\nKB: {{ $('Map File to KB').item.json.kb_id }}"
      },
      "id": "8192dbf4-1d52-47d7-bc58-0d3fde3dbafe",
      "name": "Alert Failure",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [
        960,
