# COPREM OS — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Postgres ──────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── n8n ───────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=changeme
N8N_BASE_URL=https://n8n.yourdomain.com

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-changeme
WEBHOOK_SECRET=changeme

# ── Cloudflare ────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=changeme

# ── Dify.ai ───────────────────────────────────────────────────
DIFY_API_KEY=app-changeme
DIFY_BASE_URL=https://api.dify.ai/v1

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_KEY=changeme

# ── AI Providers ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-changeme
OPENAI_API_KEY=sk-changeme
GEMINI_API_KEY=changeme

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=changeme
