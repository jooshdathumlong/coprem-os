    {
      "id": "l1a-preprocess",
      "name": "L1-A Preprocessor",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        400
      ],
      "parameters": {
        "jsCode": "const msg = $input.first().json.message;\nconst text = (msg.text || '').replace(/\\u200b/g,'').trim();\nconst userId = msg.from.id;\nconst chatId = msg.chat.id;\nconst hash = require('crypto').createHash('md5').update(userId+'|'+text).digest('hex');\nconst isStart = text === '/start';\nconst isApproval = /^(APPROVE|REJECT)\\s+\\d+/i.test(text);\nconst isThai = /[\\u0E00-\\u0E7F]/.test(text);\nreturn [{ json: { text, userId, chatId, hash, isStart, isApproval, isThai, firstName: msg.from.first_name || '', username: msg.from.username || '' } }];"
      }
    },
    {
      "id": "check-dedup",
