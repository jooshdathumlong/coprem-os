      "parameters": {
        "jsCode": "const data = $input.first().json;\nlet reply = data.answer || data.text || '\u0e02\u0e2d\u0e2d\u0e20\u0e31\u0e22 \u0e44\u0e21\u0e48\u0e2a\u0e32\u0e21\u0e32\u0e23\u0e16\u0e15\u0e2d\u0e1a\u0e44\u0e14\u0e49\u0e15\u0e2d\u0e19\u0e19\u0e35\u0e49\u0e04\u0e23\u0e31\u0e1a';\nif (reply.length > 4096) reply = reply.substring(0, 4090) + '...[\u0e15\u0e48\u0e2d]';\nconst agent = data.metadata?.usage ? 'dify' : 'unknown';\nreturn [{ json: { reply, agent } }];"
