          "name": "Postgres coprem_os"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE users SET status='{{ $json.newStatus }}', approved_at=NOW() WHERE chat_id={{ $json.targetId }}; SELECT chat_id, first_name, status FROM users WHERE chat_id={{ $json.targetId }};"
      }
    },
